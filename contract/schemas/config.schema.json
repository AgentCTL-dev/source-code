{
 "$defs": {
  "A2aPeer": {
   "additionalProperties": false,
   "properties": {
    "client_cert": {
     "description": "client certificate PEM file path (mutual TLS to the peer; requires client_key)",
     "type": "string"
    },
    "client_key": {
     "description": "client private-key PEM file path",
     "type": "string"
    },
    "endpoint": {
     "type": "string"
    },
    "headers": {
     "additionalProperties": {
      "type": "string"
     },
     "description": "secret-free auth header templates presented to the peer ({{secret:NAME}} references)",
     "type": "object"
    },
    "name": {
     "pattern": "^[a-zA-Z0-9_-]+$",
     "type": "string"
    }
   },
   "required": [
    "name",
    "endpoint"
   ],
   "type": "object"
  },
  "Limits": {
   "additionalProperties": false,
   "properties": {
    "deadline_secs": {
     "minimum": 0,
     "type": "integer"
    },
    "max_depth": {
     "minimum": 0,
     "type": "integer"
    },
    "max_steps": {
     "minimum": 1,
     "type": "integer"
    }
   },
   "type": "object"
  },
  "McpServer": {
   "additionalProperties": false,
   "properties": {
    "endpoint": {
     "type": "string"
    },
    "headers": {
     "additionalProperties": {
      "type": "string"
     },
     "type": "object"
    },
    "name": {
     "pattern": "^[a-zA-Z0-9_-]+$",
     "type": "string"
    },
    "tags": {
     "additionalProperties": {
      "items": {
       "enum": [
        "untrusted_input",
        "sensitive",
        "egress"
       ]
      },
      "type": "array"
     },
     "type": "object"
    }
   },
   "required": [
    "name",
    "endpoint"
   ],
   "type": "object"
  }
 },
 "$id": "https://agentctl.dev/contract/v2/config.schema.json",
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "additionalProperties": false,
 "properties": {
  "a2a_peers": {
   "items": {
    "$ref": "#/$defs/A2aPeer"
   },
   "type": "array"
  },
  "config_version": {
   "type": "string"
  },
  "intelligence": {
   "type": "string"
  },
  "intelligence_headers": {
   "additionalProperties": {
    "type": "string"
   },
   "type": "object"
  },
  "limits": {
   "$ref": "#/$defs/Limits"
  },
  "log_level": {
   "enum": [
    "trace",
    "debug",
    "info",
    "warn",
    "error"
   ]
  },
  "max_tokens": {
   "minimum": 1,
   "type": "integer"
  },
  "mcp_servers": {
   "items": {
    "$ref": "#/$defs/McpServer"
   },
   "type": "array"
  },
  "model": {
   "type": "string"
  },
  "model_swap": {
   "enum": [
    "finish-on-old",
    "restart-turn"
   ]
  },
  "subscribe": {
   "items": {
    "type": "string"
   },
   "type": "array"
  }
 },
 "title": "Agent Control Contract \u2014 declarative agent config file (contract 2.0)",
 "type": "object",
 "x-agentd-contract-version": "2.0",
 "x-contract-version": "2.0"
}